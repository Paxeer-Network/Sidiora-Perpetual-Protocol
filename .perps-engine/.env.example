# Required — private key with ORACLE_POSTER_ROLE on the Diamond
ORACLE_PRIVATE_KEY=0x...

# Paxeer Network RPC
RPC_URL=https://public-rpc.paxeer.app/rpc

# Diamond proxy address
DIAMOND_ADDRESS=0xeA65FE02665852c615774A3041DFE6f00fb77537

# Pyth Hermes endpoint
PYTH_HERMES_URL=https://hermes.pyth.network

# Orderly Network public API
ORDERLY_BASE_URL=https://api-evm.orderly.org

# Indexer GraphQL endpoint (for order/position cache)
INDEXER_GRAPHQL_URL=http://localhost:4000/graphql

# Cycle interval in milliseconds (default 10s)
CYCLE_INTERVAL_MS=10000

# Price deviation threshold (%) — triggers immediate cycle
DEVIATION_THRESHOLD_PCT=0.5

# Gas limit for executeCycle tx
GAS_LIMIT=2000000

# Alerting (optional)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_TELEGRAM_BOT_TOKEN=
# ALERT_TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=info
